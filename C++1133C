#include <bits/stdc++.h>
using namespace std;
 
int main(){
    ios_base::sync_with_stdio(false);
    cin.tie(nullptr);
 
    int n; 
    cin >> n;
    
    vector<int> a(n);
    for(int i = 0; i < n; i++){
        cin >> a[i];
    }
    sort(a.begin(), a.end());
 
    int l = 0, m = 0;
    for (int i = 0; i < n; i++){
        while (a[i] - a[l] > 5) {
            l++;
        }
        m = max(m, i - l + 1);
    }
    cout << m;
 
    return 0;
}
